---
import BaseLayout from "../layouts/BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { visibleBlogPosts } from "../content/utils";

const recentPosts = (await visibleBlogPosts()).slice(0, 2);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
    <h1 class="greeting">No Mana</h1>
    <blockquote>
        <p>“我们都生活在阴沟里,但仍有人仰望星空。”</p>
        <footer>—— 王尔德《温德米尔夫人的扇子》</footer>
    </blockquote>
    <blockquote>
        <p>
            “世界上只有一种真正的英雄主义,那就是在认清生活的真相之后,依然热爱生活。”
        </p>
        <footer>—— 罗曼·罗兰《米开朗琪罗传》</footer>
    </blockquote>
    <blockquote>
        <p>“十年饮冰，难凉热血。”</p>
        <footer>—— 梁启超《饮冰室文集》</footer>
    </blockquote>
    <section class="recent-posts">
        <h2 class="section-title">最近两篇</h2>
        <ul class="post-list">
            {
                recentPosts.map((post) => (
                    <li>
                        <a href={`/blog/${post.id}/`} class="post-card">
                            <div class="card-body">
                                <h3 class="card-title">{post.data.title}</h3>
                                {post.data.pubDate && (
                                    <p class="card-date">
                                        <FormattedDate
                                            date={post.data.pubDate}
                                        />
                                    </p>
                                )}
                                {post.data.description && (
                                    <p class="card-desc">
                                        {post.data.description}
                                    </p>
                                )}
                            </div>
                        </a>
                    </li>
                ))
            }
        </ul>
        <p class="more-posts">
            <a href="/blog/">查看全部 →</a>
        </p>
    </section>
</BaseLayout>

<style>
    .greeting {
        font-size: 2rem;
        margin-top: 0;
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
        color: var(--text);
    }

    code {
        font-size: 0.9em;
        padding: 2px 5px;
        border-radius: 3px;
        background: var(--code-bg);
    }

    p {
        margin-bottom: 1.2em;
        line-height: 1.7;
    }

    ul {
        padding-left: 1.5rem;
    }

    ul li {
        margin-bottom: 0.5em;
        line-height: 1.6;
    }

    blockquote {
        margin: 1.6em 0;
        padding: 0.4em 1.2em;
        border-left: 3px solid var(--text);
        color: var(--text);
        background: var(--code-bg);
        font-size: 1.05em;
        line-height: 1.8;
    }

    blockquote footer {
        margin-top: 0.4em;
        font-size: 0.85em;
        opacity: 0.7;
        text-align: right;
    }

    .recent-posts {
        margin: 2.5rem 0 0 0;
    }

    .section-title {
        font-size: 1.5rem;
        margin: 0 0 1.5rem 0;
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
        color: var(--text);
        text-align: center;
    }

    .post-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .post-card {
        display: block;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s ease;
    }

    .post-card:hover {
        transform: translateX(4px);
    }

    .card-title {
        font-size: 1.4rem;
        margin: 0 0 0.25rem 0;
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
        line-height: 1.3;
    }

    .card-date {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin: 0 0 0.5rem 0;
    }

    .card-desc {
        font-size: 0.95rem;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.5;
    }

    .more-posts {
        margin-top: 1.6em;
        text-align: center;
        font-size: 0.95rem;
    }

    .more-posts a {
        color: var(--text);
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.2s ease;
    }

    .more-posts a:hover {
        opacity: 1;
    }
</style>
