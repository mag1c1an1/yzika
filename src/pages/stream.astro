---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Let's Streaming" description="Screen streaming">
    <h1 class="page-title">Let's Streaming</h1>
    <span id="peer-status" class="pill">RTCPeerConnection: idle</span>

    <div class="stack">
        <div class="section-header">
            <h3>本地屏幕</h3>
            <div class="button-row compact">
                <button id="share" type="button">共享屏幕</button>
                <button
                    id="stop-share"
                    class="secondary"
                    type="button"
                    disabled
                >
                    停止
                </button>
            </div>
        </div>
        <video id="local-video" autoplay muted playsinline></video>
    </div>

    <section class="panel stack log-panel">
        <h2>事件日志</h2>
        <ol id="log" class="log"></ol>
    </section>
</BaseLayout>

<script>
    import {
        BROADCASTER_ID,
        CONNECTION_STATS_INTERVAL_MS,
        SCREEN_SHARE_CONTENT_HINT,
        createSignalUrl,
        describeIceRoute,
        describeScreenShareProfile,
        formatBitrate,
        getScreenShareEncodingForRoute,
        getScreenShareRouteProfile,
        getSelectedIceRoute,
        initialScreenShareEncoding,
        rtcConfig,
        screenCaptureOptions,
        type ScreenShareRouteProfile,
        type SignalMessage,
    } from "../lib/webrtc";

    const shareButton = document.querySelector<HTMLButtonElement>("#share");
    const stopShareButton =
        document.querySelector<HTMLButtonElement>("#stop-share");
    const localVideo = document.querySelector<HTMLVideoElement>("#local-video");
    const peerStatus = document.querySelector<HTMLElement>("#peer-status");
    const logList = document.querySelector<HTMLOListElement>("#log");

    let signalSocket: WebSocket | undefined;
    let screenStream: MediaStream | undefined;
    const knownViewers = new Set<string>();
    const peerConnections = new Map<string, RTCPeerConnection>();
    const pendingIceCandidates = new Map<string, RTCIceCandidateInit[]>();
    const connectionStatsIntervals = new Map<string, number>();
    const outboundStatsSnapshots = new Map<
        string,
        { bytesSent: number; timestamp: number }
    >();
    const appliedRouteProfiles = new Map<string, ScreenShareRouteProfile>();

    function addLog(message: string) {
        if (!logList) return;

        const item = document.createElement("li");
        item.textContent = `${new Date().toLocaleTimeString()} ${message}`;
        logList.prepend(item);
    }

    function setStatus(status: string) {
        if (!peerStatus) return;
        peerStatus.textContent = `RTCPeerConnection: ${status}`;
    }

    function updateStatus() {
        if (screenStream) {
            const viewerCount = peerConnections.size;
            setStatus(
                viewerCount > 0
                    ? `screen sharing (${viewerCount} viewer${viewerCount > 1 ? "s" : ""})`
                    : "screen sharing",
            );
            return;
        }

        setStatus(
            signalSocket?.readyState === WebSocket.OPEN
                ? "signal connected"
                : "idle",
        );
    }

    function setSharingState(isSharing: boolean) {
        if (!shareButton || !stopShareButton) return;

        shareButton.disabled = isSharing;
        stopShareButton.disabled = !isSharing;
    }

    function connectSignal() {
        if (
            signalSocket?.readyState === WebSocket.OPEN ||
            signalSocket?.readyState === WebSocket.CONNECTING
        ) {
            return;
        }

        signalSocket = new WebSocket(createSignalUrl(BROADCASTER_ID));

        signalSocket.addEventListener("open", () => {
            addLog("已连接信令服务");
            updateStatus();
        });

        signalSocket.addEventListener("message", handleSignalMessage);

        signalSocket.addEventListener("close", () => {
            addLog("信令连接已断开");
            updateStatus();
        });

        signalSocket.addEventListener("error", () => {
            addLog("信令连接错误");
        });
    }

    function sendSignal(payload: Record<string, unknown>) {
        if (signalSocket?.readyState !== WebSocket.OPEN) {
            addLog("信令服务未连接，消息未发送");
            return;
        }

        signalSocket.send(JSON.stringify(payload));
    }

    async function handleSignalMessage(event: MessageEvent) {
        if (typeof event.data !== "string") return;

        const message = JSON.parse(event.data) as SignalMessage;

        switch (message.type) {
            case "welcome": {
                addLog(`主播已上线：${message.peerId ?? BROADCASTER_ID}`);
                break;
            }
            case "peer-joined": {
                if (message.peerId && message.peerId !== BROADCASTER_ID) {
                    knownViewers.add(message.peerId);
                    addLog(`观众已加入：${message.peerId}`);

                    if (screenStream) {
                        await startViewerStream(message.peerId);
                    }
                }
                break;
            }
            case "peer-left": {
                if (message.peerId) {
                    knownViewers.delete(message.peerId);
                    closeViewerConnection(message.peerId);
                    addLog(`观众已离开：${message.peerId}`);
                }
                break;
            }
            case "viewer-ready": {
                if (!message.from) return;

                knownViewers.add(message.from);
                addLog(`观众请求播放：${message.from}`);

                if (screenStream) {
                    await startViewerStream(message.from);
                } else {
                    sendSignal({
                        type: "broadcast-unavailable",
                        target: message.from,
                    });
                }
                break;
            }
            case "answer": {
                await handleAnswer(message);
                break;
            }
            case "ice-candidate": {
                await addRemoteIceCandidate(message);
                break;
            }
            case "error": {
                addLog(`信令错误：${message.message ?? "unknown error"}`);
                break;
            }
        }
    }

    function createPeerConnection(viewerId: string) {
        closeViewerConnection(viewerId);

        const peerConnection = new RTCPeerConnection(rtcConfig);
        peerConnections.set(viewerId, peerConnection);

        peerConnection.addEventListener("icecandidate", (event) => {
            if (!event.candidate) return;

            sendSignal({
                type: "ice-candidate",
                target: viewerId,
                candidate: event.candidate.toJSON(),
            });
        });

        peerConnection.addEventListener("connectionstatechange", () => {
            addLog(
                `观众 ${viewerId} 连接状态：${peerConnection.connectionState}`,
            );

            if (peerConnection.connectionState === "connected") {
                startViewerStats(viewerId, peerConnection);
            }

            if (["failed", "closed"].includes(peerConnection.connectionState)) {
                closeViewerConnection(viewerId);
            }

            updateStatus();
        });

        return peerConnection;
    }

    async function applyVideoSenderLimits(
        sender: RTCRtpSender,
        encoding: RTCRtpEncodingParameters,
    ) {
        const parameters = sender.getParameters();
        parameters.encodings =
            parameters.encodings && parameters.encodings.length > 0
                ? parameters.encodings
                : [{}];
        parameters.encodings[0] = {
            ...parameters.encodings[0],
            ...encoding,
        };

        try {
            await sender.setParameters(parameters);
        } catch (error) {
            addLog("当前浏览器未完全应用视频码率限制");
            console.error(error);
        }
    }

    async function applyRouteBasedVideoLimits(
        viewerId: string,
        peerConnection: RTCPeerConnection,
        route: Awaited<ReturnType<typeof getSelectedIceRoute>>,
    ) {
        const profile = getScreenShareRouteProfile(route);
        if (
            profile === "unknown" ||
            appliedRouteProfiles.get(viewerId) === profile
        ) {
            return;
        }

        const videoSender = peerConnection
            .getSenders()
            .find((sender) => sender.track?.kind === "video");
        if (!videoSender) return;

        await applyVideoSenderLimits(
            videoSender,
            getScreenShareEncodingForRoute(route),
        );
        appliedRouteProfiles.set(viewerId, profile);
        addLog(
            `观众 ${viewerId} 已切换到${describeScreenShareProfile(profile)}`,
        );
    }

    async function getOutboundVideoBitrate(
        viewerId: string,
        peerConnection: RTCPeerConnection,
    ) {
        const stats = await peerConnection.getStats();
        let bytesSent: number | undefined;
        let timestamp: number | undefined;

        stats.forEach((stat) => {
            const outbound = stat as RTCStats & {
                bytesSent?: number;
                kind?: string;
                mediaType?: string;
            };

            if (
                stat.type === "outbound-rtp" &&
                (outbound.kind === "video" || outbound.mediaType === "video") &&
                outbound.bytesSent !== undefined
            ) {
                bytesSent = outbound.bytesSent;
                timestamp = outbound.timestamp;
            }
        });

        if (bytesSent === undefined || timestamp === undefined) {
            return undefined;
        }

        const previous = outboundStatsSnapshots.get(viewerId);
        outboundStatsSnapshots.set(viewerId, { bytesSent, timestamp });

        if (!previous || timestamp <= previous.timestamp) {
            return undefined;
        }

        return (
            ((bytesSent - previous.bytesSent) * 8 * 1000) /
            (timestamp - previous.timestamp)
        );
    }

    function startViewerStats(
        viewerId: string,
        peerConnection: RTCPeerConnection,
    ) {
        stopViewerStats(viewerId);

        const reportStats = async () => {
            const route = await getSelectedIceRoute(peerConnection);
            await applyRouteBasedVideoLimits(viewerId, peerConnection, route);
            const bitrate = await getOutboundVideoBitrate(
                viewerId,
                peerConnection,
            );
            addLog(
                `观众 ${viewerId}：${describeIceRoute(route)}，发送 ${formatBitrate(bitrate)}`,
            );
        };

        void reportStats();
        const intervalId = window.setInterval(
            () => void reportStats(),
            CONNECTION_STATS_INTERVAL_MS,
        );
        connectionStatsIntervals.set(viewerId, intervalId);
    }

    function stopViewerStats(viewerId: string) {
        const intervalId = connectionStatsIntervals.get(viewerId);
        if (intervalId !== undefined) {
            window.clearInterval(intervalId);
        }

        connectionStatsIntervals.delete(viewerId);
        outboundStatsSnapshots.delete(viewerId);
        appliedRouteProfiles.delete(viewerId);
    }

    async function startViewerStream(viewerId: string) {
        if (!screenStream) {
            sendSignal({ type: "broadcast-unavailable", target: viewerId });
            return;
        }

        try {
            const peerConnection = createPeerConnection(viewerId);

            for (const track of screenStream.getTracks()) {
                const sender = peerConnection.addTrack(track, screenStream);
                if (track.kind === "video") {
                    await applyVideoSenderLimits(
                        sender,
                        initialScreenShareEncoding,
                    );
                }
            }

            const offer = await peerConnection.createOffer();
            await peerConnection.setLocalDescription(offer);

            if (!peerConnection.localDescription) {
                throw new Error("missing local description");
            }

            sendSignal({
                type: "offer",
                target: viewerId,
                sdp: peerConnection.localDescription,
            });

            addLog(`已向观众 ${viewerId} 发送播放邀请`);
            updateStatus();
        } catch (error) {
            closeViewerConnection(viewerId);
            addLog(`无法连接观众 ${viewerId}`);
            console.error(error);
        }
    }

    async function handleAnswer(message: SignalMessage) {
        if (!message.from || !message.sdp) return;

        const peerConnection = peerConnections.get(message.from);
        if (!peerConnection) return;

        await peerConnection.setRemoteDescription(
            new RTCSessionDescription(message.sdp),
        );
        await flushPendingIceCandidates(message.from);
        addLog(`观众 ${message.from} 已接受播放`);
    }

    async function addRemoteIceCandidate(message: SignalMessage) {
        if (!message.from || !message.candidate) return;

        const peerConnection = peerConnections.get(message.from);
        if (!peerConnection) return;

        if (!peerConnection.remoteDescription) {
            const pending = pendingIceCandidates.get(message.from) ?? [];
            pending.push(message.candidate);
            pendingIceCandidates.set(message.from, pending);
            return;
        }

        await peerConnection.addIceCandidate(
            new RTCIceCandidate(message.candidate),
        );
    }

    async function flushPendingIceCandidates(viewerId: string) {
        const peerConnection = peerConnections.get(viewerId);
        const pending = pendingIceCandidates.get(viewerId) ?? [];

        if (!peerConnection || !peerConnection.remoteDescription) return;

        pendingIceCandidates.delete(viewerId);

        for (const candidate of pending) {
            await peerConnection.addIceCandidate(
                new RTCIceCandidate(candidate),
            );
        }
    }

    function closeViewerConnection(viewerId: string) {
        stopViewerStats(viewerId);
        peerConnections.get(viewerId)?.close();
        peerConnections.delete(viewerId);
        pendingIceCandidates.delete(viewerId);
        updateStatus();
    }

    function stopAllViewerConnections(notifyViewers: boolean) {
        for (const viewerId of knownViewers) {
            if (notifyViewers) {
                sendSignal({ type: "broadcast-stopped", target: viewerId });
            }
            closeViewerConnection(viewerId);
        }
    }

    function stopScreenShare() {
        stopAllViewerConnections(true);

        if (screenStream) {
            for (const track of screenStream.getTracks()) {
                track.stop();
            }
        }

        screenStream = undefined;

        if (localVideo) {
            localVideo.srcObject = null;
        }

        setSharingState(false);
        updateStatus();
        addLog("停止共享屏幕");
    }

    async function startScreenShare() {
        if (!navigator.mediaDevices?.getDisplayMedia) {
            addLog("当前浏览器不支持 getDisplayMedia");
            return;
        }

        try {
            screenStream =
                await navigator.mediaDevices.getDisplayMedia(
                    screenCaptureOptions,
                );

            if (localVideo) {
                localVideo.srcObject = screenStream;
            }

            const [videoTrack] = screenStream.getVideoTracks();
            if (videoTrack) {
                videoTrack.contentHint = SCREEN_SHARE_CONTENT_HINT;
                const settings = videoTrack.getSettings();
                addLog(
                    `共享参数：${settings.width ?? "?"}x${settings.height ?? "?"}@${settings.frameRate ?? "?"}fps`,
                );
            }

            videoTrack?.addEventListener("ended", stopScreenShare, {
                once: true,
            });

            setSharingState(true);
            updateStatus();
            addLog("开始共享屏幕");

            for (const viewerId of knownViewers) {
                await startViewerStream(viewerId);
            }
        } catch (error) {
            const message =
                error instanceof DOMException &&
                error.name === "NotAllowedError"
                    ? "取消了屏幕共享授权"
                    : "共享屏幕失败";

            updateStatus();
            addLog(message);
            console.error(error);
        }
    }

    shareButton?.addEventListener("click", startScreenShare);
    stopShareButton?.addEventListener("click", stopScreenShare);
    window.addEventListener("beforeunload", () =>
        stopAllViewerConnections(true),
    );

    setSharingState(false);
    connectSignal();
    addLog("页面已加载，点击“共享屏幕”开始。");
</script>

<style>
    .page-title {
        font-size: 2rem;
        margin-top: 0;
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
        color: var(--text);
    }

    p {
        margin-bottom: 1.2em;
        line-height: 1.7;
    }

    video {
        width: 100%;
        aspect-ratio: 16 / 9;
        border: 1px solid var(--panel-border);
        border-radius: 1rem;
        background: #020617;
    }

    .pill {
        display: inline-flex;
        width: fit-content;
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        padding: 0.35rem 0.65rem;
        background: rgba(148, 163, 184, 0.1);
        color: var(--muted);
        font-size: 0.9rem;
    }

    .panel {
        margin-top: 1rem;
        margin-bottom: 1rem;
        border: 1px solid var(--panel-border);
        border-radius: 1.25rem;
        padding: 1.25rem;
        background: rgba(17, 24, 39, 0.86);
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.18);
    }

    .stack {
        display: grid;
        align-content: start;
        gap: 1rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1rem;
    }

    .section-header h3 {
        margin: 0;
    }

    .log-panel {
        overflow: hidden;
    }

    .log {
        display: grid;
        min-height: 8rem;
        max-height: 16rem;
        margin: 0;
        padding-left: 1.5rem;
        padding-right: 0.5rem;
        overflow-y: auto;
        overscroll-behavior: contain;
        gap: 0.35rem;
        color: var(--muted);
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
            "Liberation Mono", monospace;
        font-size: 0.9rem;
    }

    .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .button-row.compact {
        gap: 0.5rem;
    }

    button {
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        padding: 0.45rem 0.9rem;
        background: var(--text);
        color: var(--bg);
        cursor: pointer;
        font: inherit;
        transition:
            opacity 0.2s ease,
            transform 0.2s ease;
    }

    button:hover:not(:disabled) {
        transform: translateY(-1px);
    }

    button.secondary {
        background: transparent;
        color: var(--text);
    }

    button:disabled {
        cursor: not-allowed;
        opacity: 0.5;
    }
</style>
