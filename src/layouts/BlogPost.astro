---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description}>
    <article>
        <header class="post-header">
            <div class="post-meta">
                <FormattedDate date={pubDate} />
                {
                    updatedDate && (
                        <span class="last-updated-on">
                            &middot; Updated{" "}
                            <FormattedDate date={updatedDate} />
                        </span>
                    )
                }
            </div>
            <h1 class="post-title">{title}</h1>
            {description && <p class="post-description">{description}</p>}
        </header>

        {
            heroImage && (
                <div class="hero-image">
                    <Image width={1020} height={510} src={heroImage} alt="" />
                </div>
            )
        }

        <div class="prose">
            <slot />
        </div>
    </article>
</BaseLayout>

<style>
    .post-header {
        margin-bottom: 2rem;
    }

    .post-meta {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 0.5rem;
    }

    .post-title {
        font-size: 2.2em;
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
        color: var(--text);
    }

    .post-description {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin: 0;
    }

    .hero-image {
        margin-bottom: 2rem;
    }

    .hero-image img {
        display: block;
        width: 100%;
        border-radius: 12px;
        box-shadow: var(--shadow);
    }

    /* Prose content */
    .prose {
        font-size: 1.05rem;
        line-height: 1.8;
    }

    .prose :global(h2) {
        font-size: 1.6em;
        margin-top: 2em;
        margin-bottom: 0.5em;
        color: var(--text);
    }

    .prose :global(h3) {
        font-size: 1.3em;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
    }

    .prose :global(p) {
        margin-bottom: 1.5em;
    }

    .prose :global(blockquote) {
        border-left: 4px solid var(--primary);
        padding: 0 0 0 1rem;
        margin: 1.5em 0;
        font-style: italic;
        color: var(--text-secondary);
    }

    .prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
    }

    .prose :global(pre) {
        padding: 1.5em;
        border-radius: 8px;
        overflow-x: auto;
        font-size: 0.9rem;
    }

    .prose :global(code) {
        font-size: 0.9em;
        padding: 2px 5px;
        border-radius: 3px;
        background: var(--code-bg);
    }

    .prose :global(pre code) {
        background: none;
        padding: 0;
    }

    .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2em 0;
    }
</style>
