---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import JumpToTop from "../components/JumpToTop.astro";
import DarkModeToggle from "../components/DarkModeToggle.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

export interface Props {
    title?: string;
    description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <!-- Dark mode init (before paint) + toggle function -->
        <script is:inline>
            // Toggle dark mode (called from onclick)
            function toggleDarkMode() {
                var html = document.documentElement;
                var isDark = html.classList.toggle("dark");
                localStorage.setItem("theme", isDark ? "dark" : "light");
            }
            // Init: restore saved preference or respect system
            (function () {
                var stored = localStorage.getItem("theme");
                var prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                if (stored === "dark" || (!stored && prefersDark)) {
                    document.documentElement.classList.add("dark");
                }
            })();
        </script>
        <BaseHead title={title} description={description} />
    </head>
    <body id="theme-typography" class="font-typography">
        <div class="layout-wrapper">
            <!-- 桌面端侧边栏 -->
            <header class="sidebar">
                <Header />
                <Footer />
            </header>

            <!-- 主内容区 (可滚动) -->
            <main class="content-area">
                <!-- 移动端顶部导航 -->
                <nav class="mobile-nav md:hidden">
                    <Header />
                </nav>

                <div class="content-inner">
                    <slot />
                </div>

                <!-- 移动端底部 -->
                <div class="md:hidden">
                    <Footer />
                </div>
            </main>
        </div>

        <DarkModeToggle />
        <JumpToTop />
    </body>
</html>

<style is:global>
    /* ===== Typography Theme Layout & Effects ===== */

    /* Font stack from typography theme */
    .font-typography {
        font-weight: 400;
        font-family:
            "Source Sans Pro", Roboto, Helvetica, "Helvetica Neue",
            "Source Han Sans SC", "Source Han Sans TC", "PingFang SC",
            "PingFang HK", "PingFang TC", sans-serif !important;
        line-height: 1.7;
        font-size: 18px;
    }

    /* Grid background texture */
    #theme-typography {
        background-color: var(--bg);
        color: var(--text);
        background-size: 7px 7px;
        text-shadow: 1px 1px 1px rgb(0 0 0 / 0.04);
        background-image:
            linear-gradient(to right, rgb(0 0 0 / 0.04) 1px, transparent 1px),
            linear-gradient(to bottom, rgb(0 0 0 / 0.04) 1px, transparent 1px);
        min-height: 100vh;
    }

    /* Dark mode: lighter grid on dark bg */
    .dark #theme-typography {
        background-image:
            linear-gradient(
                to right,
                rgb(255 255 255 / 0.04) 1px,
                transparent 1px
            ),
            linear-gradient(
                to bottom,
                rgb(255 255 255 / 0.04) 1px,
                transparent 1px
            );
        text-shadow: none;
    }

    /* Blog name serif font */
    .blog-name {
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
    }

    .blog-name-en {
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
    }

    .blog-item-title {
        color: #276077;
    }

    .dark .blog-item-title {
        color: #d1d5db;
    }

    /* Layout: two-column */
    .layout-wrapper {
        display: flex;
        margin: 0 auto;
        max-width: 100%;
        min-height: 100vh;
    }

    /* Sidebar (desktop only) */
    .sidebar {
        display: none;
    }

    @media (min-width: 768px) {
        .layout-wrapper {
            max-width: 80rem;
            padding: 0 6rem;
        }

        .sidebar {
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            width: 280px;
            height: 100vh;
            position: sticky;
            top: 0;
            padding: 2rem 1.5rem 1rem;
            box-sizing: border-box;
        }

        .content-area {
            flex: 1;
            overflow-y: auto;
            padding: 2rem 2rem 2rem 0;
            min-height: 100vh;
        }
    }

    /* Content area (mobile) */
    .content-area {
        flex: 1;
        padding: 1rem;
        max-width: 100%;
        overflow-y: auto;
    }

    .content-inner {
        max-width: 720px;
        margin: 0 auto;
    }

    /* Hide scrollbar for content area */
    .scroll-hidden {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .scroll-hidden::-webkit-scrollbar {
        display: none;
    }

    @media (max-width: 767px) {
        .font-typography {
            font-size: 16px;
        }
    }
</style>
