---
import githubAvatar from "../assets/github-avatar.png";
import { SITE_AUTHOR, SITE_GITHUB, SITE_TITLE, SITE_TITLE_EN } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const githubProfileUrl = `https://github.com/${SITE_GITHUB}`;
---

<div class="nav-wrapper">
    <a href="/" class="site-title" aria-label={SITE_TITLE}>
        <div class="site-title-inner">
            {
                SITE_TITLE_EN && (
                    <span class="site-name-en blog-name-en">
                        {SITE_TITLE_EN}
                    </span>
                )
            }
            <h1 class="site-name blog-name">{SITE_TITLE}</h1>
        </div>
    </a>

    <div class="site-profile">
        <a
            class="site-avatar"
            href={githubProfileUrl}
            target="_blank"
            rel="noreferrer"
            aria-label={`${SITE_AUTHOR} 的 GitHub 主页`}
            title="GitHub"
        >
            <img
                src={githubAvatar.src}
                alt={`${SITE_AUTHOR} avatar`}
                loading="eager"
            />
        </a>
        <div class="site-author">{SITE_AUTHOR}</div>
    </div>

    <div class="nav-block">
        <nav class="nav-links" aria-label="Primary">
            <HeaderLink href="/">Home</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
            <HeaderLink href="/about">About</HeaderLink>
        </nav>

        <div class="nav-social" aria-label="Social links">
            <a
                href={githubProfileUrl}
                target="_blank"
                rel="noreferrer"
                aria-label="GitHub"
                title="GitHub"
            >
                <svg
                    viewBox="0 0 16 16"
                    aria-hidden="true"
                    width="22"
                    height="22"
                >
                    <path
                        fill="currentColor"
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                    ></path>
                </svg>
            </a>
        </div>
    </div>
</div>

<style>
    .nav-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .site-title {
        width: fit-content;
        display: inline-block;
        text-decoration: none;
        color: var(--text);
    }

    .site-title-inner {
        display: flex;
        flex-direction: column-reverse;
        align-items: center;
        gap: 0.15rem;
        padding: 0.5rem 0.85rem;
        transition:
            background 0.7s ease,
            color 0.7s ease,
            padding 0.7s ease;
    }

    .site-title:hover .site-title-inner {
        background: var(--primary);
        color: var(--bg);
    }

    .site-name,
    .site-name-en {
        margin: 0;
        line-height: 1.1;
        color: inherit;
    }

    .site-name {
        font-size: 2rem;
        text-align: center;
    }

    .site-name-en {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-align: center;
        opacity: 0.9;
    }

    .site-profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: fit-content;
        gap: 0.55rem;
    }

    .site-avatar {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 9999px;
        display: block;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition:
            transform 0.2s ease,
            rotate 0.2s ease,
            box-shadow 0.2s ease;
    }

    .site-avatar img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: inherit;
    }

    .site-avatar:hover {
        transform: scale(1.08);
        rotate: 12deg;
    }

    .site-author {
        font-size: 0.95rem;
        font-weight: 700;
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
        color: var(--text);
        letter-spacing: 0.02em;
        text-align: center;
    }

    .nav-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        gap: 0.9rem;
    }

    .nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }

    .nav-links :global(a) {
        display: block;
        padding: 0.25rem 0;
        font-family:
            HiraMinProN-W6, "Source Han Serif CN", "Source Han Serif SC",
            "Source Han Serif TC", serif;
        color: var(--text);
        opacity: 0.82;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        transition:
            color 0.2s ease,
            opacity 0.2s ease,
            border-color 0.2s ease;
    }

    .nav-links :global(a:hover),
    .nav-links :global(a.active) {
        opacity: 1;
        color: var(--text);
        border-bottom-color: var(--primary);
    }

    .nav-social {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        gap: 0.75rem;
    }

    .nav-social a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text);
        opacity: 0.7;
        transition:
            opacity 0.2s ease,
            transform 0.2s ease,
            color 0.2s ease;
        text-decoration: none;
    }

    .nav-social a:hover {
        opacity: 1;
        transform: translateY(-1px);
    }

    @media (max-width: 767px) {
        .nav-wrapper {
            padding: 0.5rem 0 1rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 1rem;
        }
    }

    @media (min-width: 768px) {
        .nav-wrapper {
            width: 100%;
            align-items: center;
            gap: 0.85rem;
        }

        .site-title {
            display: flex;
            width: 100%;
            justify-content: center;
        }

        .site-title-inner {
            display: inline-flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.35rem;
            width: fit-content;
            border-left: 2px solid var(--primary);
            padding: 0 0 0 1rem;
            writing-mode: vertical-lr;
        }

        .site-title:hover .site-title-inner {
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .site-name {
            font-size: 2.25rem;
            text-align: left;
        }

        .site-name-en {
            font-size: 1.15rem;
            text-align: left;
        }

        .site-profile {
            align-items: center;
            justify-content: center;
            width: 100%;
        }

        .site-author {
            width: 100%;
            text-align: center;
        }

        .nav-block {
            align-items: center;
            justify-content: flex-start;
            width: 100%;
            margin-top: 0.25rem;
        }

        .nav-links {
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            width: 100%;
            gap: 0.5rem;
        }

        .nav-social {
            justify-content: center;
        }

        .nav-links :global(a) {
            width: 100%;
            box-sizing: border-box;
            text-align: center;
            border-left: none;
            padding-left: 0;
        }

        .nav-links :global(a:hover),
        .nav-links :global(a.active) {
            border-left-color: transparent;
            border-bottom-color: var(--primary);
        }
    }
</style>
