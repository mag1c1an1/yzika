---
const today = new Date();
---

<footer class="site-footer">
    <p>&copy; {today.getFullYear()} All rights reserved.</p>
</footer>

<style>
    .site-footer {
        padding: 1rem 0;
        font-size: 0.875rem;
        color: var(--text-secondary);
        text-align: left;
    }

    .site-footer p {
        margin: 0;
    }

    @media (max-width: 767px) {
        .site-footer {
            text-align: center;
            padding: 2rem 0;
        }
    }
</style>
